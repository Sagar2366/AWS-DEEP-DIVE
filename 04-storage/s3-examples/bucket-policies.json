{
  "Description": "Common S3 bucket policy examples for interview prep and hands-on practice",

  "Example1_PublicReadOnly": {
    "Description": "Allow public read access to all objects (use with caution — only for truly public content like static websites)",
    "Policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "PublicReadGetObject",
          "Effect": "Allow",
          "Principal": "*",
          "Action": "s3:GetObject",
          "Resource": "arn:aws:s3:::my-public-website-bucket/*"
        }
      ]
    }
  },

  "Example2_EnforceSSLOnly": {
    "Description": "Deny all requests that don't use HTTPS — a common compliance requirement and interview favorite",
    "Policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "DenyInsecureTransport",
          "Effect": "Deny",
          "Principal": "*",
          "Action": "s3:*",
          "Resource": [
            "arn:aws:s3:::my-secure-bucket",
            "arn:aws:s3:::my-secure-bucket/*"
          ],
          "Condition": {
            "Bool": {
              "aws:SecureTransport": "false"
            }
          }
        }
      ]
    }
  },

  "Example3_CrossAccountAccess": {
    "Description": "Allow another AWS account (111122223333) to read objects — common in multi-account setups",
    "Policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "CrossAccountRead",
          "Effect": "Allow",
          "Principal": {
            "AWS": "arn:aws:iam::111122223333:root"
          },
          "Action": [
            "s3:GetObject",
            "s3:ListBucket"
          ],
          "Resource": [
            "arn:aws:s3:::my-shared-bucket",
            "arn:aws:s3:::my-shared-bucket/*"
          ]
        }
      ]
    }
  },

  "Example4_RestrictToVPCEndpoint": {
    "Description": "Only allow access from a specific VPC endpoint — ensures traffic never traverses the internet",
    "Policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "DenyAccessExceptFromVPCEndpoint",
          "Effect": "Deny",
          "Principal": "*",
          "Action": "s3:*",
          "Resource": [
            "arn:aws:s3:::my-private-bucket",
            "arn:aws:s3:::my-private-bucket/*"
          ],
          "Condition": {
            "StringNotEquals": {
              "aws:sourceVpce": "vpce-0a1b2c3d4e5f6g7h8"
            }
          }
        }
      ]
    }
  },

  "Example5_RestrictToIPRange": {
    "Description": "Only allow access from a specific IP range (e.g., corporate office)",
    "Policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "DenyAccessFromNonCorporateIPs",
          "Effect": "Deny",
          "Principal": "*",
          "Action": "s3:*",
          "Resource": [
            "arn:aws:s3:::my-corp-bucket",
            "arn:aws:s3:::my-corp-bucket/*"
          ],
          "Condition": {
            "NotIpAddress": {
              "aws:SourceIp": [
                "203.0.113.0/24",
                "198.51.100.0/24"
              ]
            }
          }
        }
      ]
    }
  },

  "Example6_EnforceKMSEncryption": {
    "Description": "Deny any upload that doesn't use SSE-KMS encryption — common compliance policy",
    "Policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "DenyUnencryptedUploads",
          "Effect": "Deny",
          "Principal": "*",
          "Action": "s3:PutObject",
          "Resource": "arn:aws:s3:::my-encrypted-bucket/*",
          "Condition": {
            "StringNotEquals": {
              "s3:x-amz-server-side-encryption": "aws:kms"
            }
          }
        },
        {
          "Sid": "DenyUnencryptedHeader",
          "Effect": "Deny",
          "Principal": "*",
          "Action": "s3:PutObject",
          "Resource": "arn:aws:s3:::my-encrypted-bucket/*",
          "Condition": {
            "Null": {
              "s3:x-amz-server-side-encryption": "true"
            }
          }
        }
      ]
    }
  },

  "Example7_CloudFrontOriginAccessControl": {
    "Description": "Allow only CloudFront to read objects — prevents direct S3 access (used for static website hosting behind CloudFront)",
    "Policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "AllowCloudFrontServicePrincipal",
          "Effect": "Allow",
          "Principal": {
            "Service": "cloudfront.amazonaws.com"
          },
          "Action": "s3:GetObject",
          "Resource": "arn:aws:s3:::my-website-bucket/*",
          "Condition": {
            "StringEquals": {
              "AWS:SourceArn": "arn:aws:cloudfront::123456789012:distribution/E1A2B3C4D5E6F7"
            }
          }
        }
      ]
    }
  },

  "InterviewTip": "When asked about S3 security: (1) Block Public Access is the first line of defense. (2) Bucket policies control access at the bucket level. (3) IAM policies control access at the user/role level. (4) Encryption policies enforce SSE-KMS/SSE-S3. (5) VPC endpoint policies restrict network path. Always layer these — defense in depth."
}
